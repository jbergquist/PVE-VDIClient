<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.proxmox.VDIClient</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>Apache-2.0</project_license>
  <name>PVE VDI Client</name>
  <summary>Web-based client for Proxmox VE Virtual Desktop Infrastructure</summary>

  <description>
    <p>
      PVE VDI Client provides a modern web interface for accessing virtual
      desktops in Proxmox VE environments. It supports the SPICE protocol
      for remote desktop access and integrates with virt-viewer for launching
      VM console sessions.
    </p>
    <p>Features:</p>
    <ul>
      <li>Web-based login and VM selection interface</li>
      <li>SPICE protocol support for virtual desktops</li>
      <li>Integration with Proxmox VE authentication</li>
      <li>Support for multiple Proxmox clusters</li>
      <li>Session timeout and automatic server shutdown</li>
      <li>Compatible with Proxmox VE 7, 8, and 9</li>
    </ul>
  </description>

  <launchable type="desktop-id">org.proxmox.VDIClient.desktop</launchable>

  <url type="homepage">https://github.com/jbergquist/PVE-VDIClient</url>
  <url type="bugtracker">https://github.com/jbergquist/PVE-VDIClient/issues</url>
  <url type="vcs-browser">https://github.com/jbergquist/PVE-VDIClient</url>

  <developer_name>jbergquist</developer_name>

  <categories>
    <category>System</category>
    <category>RemoteAccess</category>
    <category>Network</category>
  </categories>

  <keywords>
    <keyword>proxmox</keyword>
    <keyword>vdi</keyword>
    <keyword>spice</keyword>
    <keyword>virtualization</keyword>
    <keyword>remote</keyword>
    <keyword>desktop</keyword>
  </keywords>

  <screenshots>
